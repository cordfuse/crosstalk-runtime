{
  "name": "@cordfuse/crosstalk-runtime",
  "version": "1.4.0",
  "description": "Crosstalk runtime — watches a transport for new messages and dispatches to registered actor processes",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "crosstalk": "dist/index.js",
    "ct": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "test": "bun test src/*.test.ts src/cli/commands/*.test.ts"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@inquirer/prompts": "^8.4.3",
    "age-encryption": "^0.3.0",
    "commander": "^14.0.3",
    "smol-toml": "^1.6.1",
    "which": "^4.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/which": "^3.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.5.0"
  }
}
