{
  "name": "@crosstalk/runtime",
  "version": "0.5.0-alpha.1",
  "description": "Crosstalk runtime — watches a transport for new messages and dispatches to registered actor processes",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "crosstalk": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "build": "bun build --compile --minify src/index.ts --outfile crosstalk"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "commander": "^14.0.3",
    "smol-toml": "^1.6.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
