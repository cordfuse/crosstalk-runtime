{
  "name": "@cordfuse/crosstalk-runtime",
  "version": "3.0.0",
  "description": "Crosstalk runtime — lean scheduler that dispatches agent CLIs on a shared git transport",
  "type": "module",
  "main": "dist/runner.js",
  "bin": {
    "crosstalk": "dist/runner.js",
    "ct": "dist/runner.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "start": "node dist/runner.js",
    "dev": "bun --watch src/runner.ts"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@cordfuse/turnq": "^0.3.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
